{
  "name": "sbcalc-web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "Skyblock Calculator Web App - Frontend for calculating Minecraft Hypixel Skyblock item recipes and requirements",
  "keywords": [
    "minecraft",
    "hypixel",
    "skyblock",
    "calculator",
    "nextjs",
    "react"
  ],
  "scripts": {
    "generate:recipes": "pnpm --filter sbcalc-web run generate:recipes",
    "generate:recipes:clean": "pnpm --filter sbcalc-web run generate:recipes:clean",
    "dev": "pnpm run generate:recipes && next dev --turbopack",
    "build": "pnpm run generate:recipes && next build",
    "build:clean": "pnpm run generate:recipes:clean && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@next/third-parties": "16.0.7",
    "@vercel/og": "^0.8.5",
    "@workspace/neu-recipe-processor": "workspace:*",
    "@workspace/snbt-parser": "workspace:*",
    "@workspace/ui": "workspace:*",
    "lucide-react": "0.552.0",
    "next": "16.0.7",
    "next-themes": "^0.4.4",
    "radix-ui": "^1.4.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sonner": "^2.0.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.0.6",
    "@vitest/ui": "4.0.6",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "jsdom": "27.1.0",
    "typescript": "^5.9.2",
    "vitest": "4.0.6"
  }
}
