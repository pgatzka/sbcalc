{
  "name": "sbcalc",
  "version": "0.0.1",
  "private": true,
  "description": "Skyblock Calculator - A comprehensive tool for calculating Minecraft Hypixel Skyblock item recipes, forge times, and base requirements",
  "keywords": [
    "minecraft",
    "hypixel",
    "skyblock",
    "calculator",
    "recipes",
    "items",
    "forge"
  ],
  "author": "Hexeption",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hexeption/sbcalc.git"
  },
  "bugs": {
    "url": "https://github.com/Hexeption/sbcalc/issues"
  },
  "homepage": "https://sbcalc.net",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "generate:recipes": "node scripts/generate-recipes.js",
    "generate:recipes:clean": "node scripts/generate-recipes-clean.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@workspace/typescript-config": "workspace:*",
    "turbo": "^2.9.5",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js-pure",
      "esbuild",
      "sharp"
    ]
  }
}
