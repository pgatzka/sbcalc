{
  "name": "@workspace/neu-recipe-processor",
  "version": "1.0.0",
  "description": "Process NotEnoughUpdates repository JSON files and combine items with recipes for Hypixel Skyblock",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Hexeption",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "clean:neu": "rm -rf ./output/NotEnoughUpdates-REPO",
    "clean:outputs": "rm -f ./output/merged_items.json ./output/recipes_items.json",
    "build:clean": "pnpm run clean:neu && pnpm run clean:outputs && pnpm run build && pnpm run start"
  },
  "dependencies": {
    "simple-git": "^3.19.1",
    "fs-extra": "^11.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/fs-extra": "^11.0.1",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "skyblock",
    "hypixel",
    "neu",
    "recipes",
    "minecraft",
    "items",
    "data-processing",
    "json",
    "calculator"
  ]
}
